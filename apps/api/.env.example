# ─────────────────────────────────────────────────────────────────────────────
# Naglity API — environment variables
# Copy to .env (local dev) and set the equivalents in your prod API host.
# Values marked "differs" MUST be different between dev and prod.
# ─────────────────────────────────────────────────────────────────────────────

# Database — DIFFERS per environment (separate Neon DB/branch for dev vs prod)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth — JWT_SECRET DIFFERS per environment (security: dev tokens must not work in prod).
# Generate a strong one:  openssl rand -base64 48
JWT_SECRET="change-me-unique-per-environment"
JWT_EXPIRES_IN="24h"

# CORS / realtime origin — DIFFERS: the web app URL allowed to call this API.
# dev:  http://localhost:3000   prod: https://your-production-domain.com
FRONTEND_URL="http://localhost:3000"

# Runtime
PORT=3001
# DIFFERS: "development" locally, "production" in prod (enables secure cookies, etc.)
NODE_ENV="development"

# Payments — "fake" (no external account, simulated) or "stripe" (later).
PAYMENTS_PROVIDER="fake"
# Future, when wiring real Stripe — DIFFERS: TEST keys in dev, LIVE keys in prod.
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
