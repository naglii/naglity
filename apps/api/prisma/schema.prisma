generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DRIVER
  BUSINESS
}

enum JobStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  PAID
  DELETED
}

enum JobEventType {
  ACCEPTED
  CANCELLED_BY_DRIVER
  DELETED_BY_BUSINESS
  STARTED
  COMPLETED
  PAID
}

enum NotificationType {
  JOB_ACCEPTED_BY_DRIVER
  JOB_CANCELLED_BY_DRIVER
  JOB_DELETED_BY_BUSINESS
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String?        @unique
  passwordHash  String
  role          Role
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  driver        Driver?
  business      Business?
  notifications Notification[]
  jobEvents     JobEvent[]
}

model Driver {
  id            String   @id @default(cuid())
  userId        String   @unique
  name          String
  phone         String
  vehicleNumber String
  vehicleType   String   @default("crane_truck")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs          Job[]

  @@index([userId])
}

model Business {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs      Job[]

  @@index([userId])
}

model Job {
  id              String         @id @default(cuid())
  businessId      String
  driverId        String?
  status          JobStatus      @default(OPEN)
  title           String
  description     String?
  grossPriceCents Int
  scheduledAt     DateTime
  estimatedEndAt  DateTime
  fromLocation    String
  toLocation      String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  business        Business       @relation(fields: [businessId], references: [id])
  driver          Driver?        @relation(fields: [driverId], references: [id])
  events          JobEvent[]
  notifications   Notification[]

  @@index([status])
  @@index([businessId])
  @@index([driverId])
  @@index([scheduledAt])
}

model JobEvent {
  id        String       @id @default(cuid())
  jobId     String
  actorId   String
  type      JobEventType
  createdAt DateTime     @default(now())
  job       Job          @relation(fields: [jobId], references: [id])
  actor     User         @relation(fields: [actorId], references: [id])

  @@index([jobId])
  @@index([actorId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  jobId     String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([jobId])
}
