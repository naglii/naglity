generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DRIVER
  BUSINESS
}

enum JobStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  PAID
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String?   @unique
  passwordHash String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  driver       Driver?
  business     Business?
}

model Driver {
  id            String   @id @default(cuid())
  userId        String   @unique
  name          String
  phone         String
  vehicleNumber String
  vehicleType   String   @default("crane_truck")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs          Job[]

  @@index([userId])
}

model Business {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs      Job[]

  @@index([userId])
}

model Job {
  id              String    @id @default(cuid())
  businessId      String
  driverId        String?
  status          JobStatus @default(OPEN)
  title           String
  description     String?
  grossPriceCents Int
  scheduledAt     DateTime
  estimatedEndAt  DateTime
  fromLocation    String
  toLocation      String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  business        Business  @relation(fields: [businessId], references: [id])
  driver          Driver?   @relation(fields: [driverId], references: [id])

  @@index([status])
  @@index([businessId])
  @@index([driverId])
  @@index([scheduledAt])
}
